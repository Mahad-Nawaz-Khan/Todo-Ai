# Database Configuration
DATABASE_URL=sqlite:///./todo_ai.db
# For PostgreSQL (Neon Serverless PostgreSQL recommended):
# DATABASE_URL=postgresql://username:password@localhost:5432/todo_ai
# For Neon (get connection string from https://console.neon.tech):
# DATABASE_URL=postgresql://username:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# SQL Echo (set to "1" or "true" to see SQL queries)
SQL_ECHO=

# Server Configuration
PORT=8000
HOST=0.0.0.0

# Frontend URL for CORS (your deployed Vercel app)
FRONTEND_URL=https://hackathon-2-phase-3-giaic.vercel.app

# CORS Origins (comma-separated list of allowed origins) - legacy, use FRONTEND_URL instead
CORS_ORIGINS=http://localhost:3000,https://hackathon-2-phase-3-giaic.vercel.app

# ============================================================================
# AI Configuration - Z.ai API
# ============================================================================
# Get your Z.ai API key from: https://z.ai/
# The system uses OpenAI Agents SDK with Z.ai's OpenAI-compatible endpoint

Z_AI_API_KEY=your_z_ai_api_key_here
# Available models (change as needed):
# - gpt-4o (recommended, most capable)
# - gpt-4o-mini (faster, cheaper)
Z_AI_MODEL=glm-4.7-flash

# Legacy: Gemini API (fallback if Z_AI_API_KEY not set)
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.0-flash-exp

# ============================================================================
# Authentication Configuration
# ============================================================================
# FastAPI accepts app-issued JWTs and can optionally continue to accept Clerk JWTs
# during migration.

APP_JWT_SECRET=replace_with_a_long_random_secret
APP_JWT_ISSUER=todo-ai-auth
# APP_JWT_AUDIENCE=todo-ai-api

# Optional legacy Clerk validation during migration
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here
CLERK_JWT_KEY=sk_test_your_clerk_secret_key_here
CLERK_ISSUER=https://your-clerk-instance.clerk.accounts
CLERK_JWKS_URL=https://your-clerk-instance.clerk.accounts/.well-known/jwks.json
# CLERK_JWT_AUDIENCE=your_audience_if_needed

# OAuth provider metadata used by the Next.js auth layer
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
NEXTAUTH_URL=http://localhost:3000
AUTH_CALLBACK_URL=http://localhost:3000/api/auth/callback

# ============================================================================
# Rate Limiting
# ============================================================================
RATE_LIMIT_ENABLED=true

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=INFO
